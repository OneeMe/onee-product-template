{
  "name": "onee-product-template",
  "version": "0.1.0",
  "description": "A public GitHub template repository for npm-workspace TypeScript projects.",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "postinstall": "node scripts/prepare-project.mjs",
    "format": "prettier --write .",
    "lint": "npm run format:check && npm run lint:eslint && npm run type-check",
    "test": "vitest run --coverage --passWithNoTests && node scripts/update-quality-baselines.mjs",
    "build": "npm run build --workspaces --if-present",
    "e2e": "npm run e2e:integration && npm run e2e:template && npm run e2e:apps",
    "e2e:apps": "node scripts/run-app-e2e.mjs",
    "e2e:integration": "vitest run --config vitest.e2e.config.ts --passWithNoTests",
    "e2e:template": "node e2e/template/run.mjs",
    "eval": "vitest run --config vitest.eval.config.ts",
    "clean": "node scripts/clean.mjs",
    "format:check": "prettier --check .",
    "lint:eslint": "eslint .",
    "test:watch": "vitest",
    "type-check": "tsc -b && tsc --project tsconfig.quality.json"
  },
  "devDependencies": {
    "@eslint/js": "^9.31.0",
    "@types/node": "^24.0.14",
    "@vitest/coverage-v8": "^3.2.7",
    "eslint": "^9.31.0",
    "prettier": "^3.6.2",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.36.0",
    "vitest": "^3.2.4"
  }
}
